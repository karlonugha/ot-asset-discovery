# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ot_asset_discovery

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# Network Capture
CAPTURE_INTERFACE=eth0

# Vulnerability Database (optional)
VULN_DB_URL=

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
